pipeline {
    agent any
    environment {
        DOCKER_HUB_USER = 'gopiborra227'   // your Docker Hub username
        IMAGE_NAME      = 'task-manager-enterprise'
        REGISTRY_TAG    = "${DOCKER_HUB_USER}/${IMAGE_NAME}:${BUILD_NUMBER}"
    }
    stages {
        stage('Checkout SCM') {
            steps {
                checkout scm
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -f Docker/Dockerfile -t ${REGISTRY_TAG} ."
            }
        }

        stage('Security Check') {
            steps {
                echo 'Executing static analysis security validation checks...'
                // Add tools like Trivy, Anchore, or Snyk here later
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-login', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    sh "echo ${PASS} | docker login -u ${USER} --password-stdin"
                    sh "docker push ${REGISTRY_TAG}"
                }
            }
        }

        stage('Update GitOps Manifest') {
            steps {
                sh """
                sed -i 's|image: .*|image: ${REGISTRY_TAG}|g' k8s-gitops/app-deployment.yaml
                git config user.email "ci-bot@example.com"
                git config user.name "ci-bot"
                git add k8s-gitops/app-deployment.yaml
                git commit -m "ci: update image tag to ${REGISTRY_TAG}"
                git push origin main
                """
                echo 'Updated Kubernetes manifest with new image tag and pushed to GitHub.'
            }
        }
    }
}
        stage('Update GitOps Manifest') {
            steps {
                sh '''
                git config user.email "ci-bot@example.com"
                git config user.name "ci-bot"
                git add k8s-gitops/app-deployment.yaml
                git commit -m "ci: update image tag to ${REGISTRY_TAG}"
                git push origin main
            '''
                echo 'Updated Kubernetes manifest with new image tag and pushed to GitHub.'
    }
}
